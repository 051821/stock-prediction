{
  "title": "Stock Prediction System",
  "uid": "stock-pred-v1",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(stock_api_requests_total[1m])",
          "legendFormat": "{{symbol}} - {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 API Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(stock_api_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 - {{symbol}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(stock_api_latency_seconds_bucket[5m]))",
          "legendFormat": "P50 - {{symbol}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latest Predicted Prices (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "stock_predicted_price_usd",
          "legendFormat": "{{symbol}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Model R² Score per Symbol",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "stock_model_r2_score",
          "legendFormat": "{{symbol}}"
        }
      ],
      "options": {
        "minValue": 0,
        "maxValue": 1,
        "thresholds": {
          "steps": [
            { "color": "red",    "value": 0   },
            { "color": "yellow", "value": 0.7 },
            { "color": "green",  "value": 0.9 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Active Requests (in-flight)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 4 },
      "targets": [
        { "expr": "stock_api_active_requests", "legendFormat": "Active" }
      ]
    },
    {
      "id": 6,
      "title": " Model Cache Hits",
      "type": "stat",
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 4 },
      "targets": [
        { "expr": "stock_model_cache_hits_total", "legendFormat": "Cache Hits" }
      ]
    },
    {
      "id": 7,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "rate(stock_api_requests_total{status='error'}[5m]) / rate(stock_api_requests_total[5m]) * 100",
          "legendFormat": "Error Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      }
    }
  ]
}
