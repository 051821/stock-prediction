FROM python:3.11-slim
 
RUN useradd -m -u 1000 appuser
WORKDIR /app
 
COPY requirements.txt .
RUN pip install --no-cache-dir streamlit plotly requests
 
COPY --chown=appuser:appuser app/app.py .
 
USER appuser
EXPOSE 8504
 
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8504/_stcore/health')"
 
CMD ["streamlit", "run", "app.py", "--server.port=8504", "--server.address=0.0.0.0", "--server.headless=true"]
 
